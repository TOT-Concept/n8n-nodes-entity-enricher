{
	"name": "n8n-nodes-entity-enricher",
	"version": "1.0.1",
	"description": "n8n community node for Entity Enricher — enrich entities with multi-model LLM fusion, multilingual output, and expertise-driven strategies",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"entity-enricher",
		"llm",
		"enrichment",
		"ai"
	],
	"license": "MIT",
	"author": {
		"name": "TOT Concept"
	},
	"homepage": "https://entityenricher.ai/docs/integrations/n8n",
	"repository": {
		"type": "git",
		"url": "https://github.com/TOT-Concept/n8n-nodes-entity-enricher.git"
	},
	"bugs": {
		"url": "https://github.com/TOT-Concept/n8n-nodes-entity-enricher/issues"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/EntityEnricherApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/EntityEnricher/EntityEnricher.node.js"
		]
	},
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "n8n-node dev --external-n8n",
		"lint": "tsc --noEmit",
		"prepublishOnly": "npm run build",
		"sync-workflows": "bash ../sync-workflows.sh push",
		"sync-workflows:push": "bash ../sync-workflows.sh push",
		"sync-workflows:pull": "bash ../sync-workflows.sh pull"
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@n8n/node-cli": "^0.23.0",
		"@types/node": "^22.0.0",
		"gulp": "^5.0.0",
		"n8n-workflow": "^1.72.0",
		"typescript": "^5.7.0"
	},
	"peerDependencies": {
		"n8n-workflow": ">=1.0.0"
	}
}
